# === Base de datos: Supabase (PostgreSQL) ===
# En Supabase: Project Settings → Database → Connection string.
# DATABASE_URL = conexión POOLED (Transaction, puerto 6543) + ?pgbouncer=true
DATABASE_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL = conexión DIRECTA (puerto 5432) — Prisma la usa para migraciones / db push
DIRECT_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# === Auth ===
JWT_SECRET="cambia-este-secreto-en-produccion"
JWT_EXPIRES_IN="7d"

# === Pago SINPE / WhatsApp (datos reales NMRC) ===
SINPE_NUMBER="8576-3191"
WHATSAPP_NUMBER="50685763191"

# === Envío (en céntimos: colones × 100) ===
SHIPPING_FLAT_CENTS="300000"        # ₡3.000 de envío plano
FREE_SHIPPING_MIN_CENTS="6000000"   # gratis a partir de ₡60.000

# === Servidor ===
PORT=3000
# Dominios del frontend (Vercel), separados por coma:
CORS_ORIGINS="http://localhost:5173,http://localhost:5174"
# URL pública de la API (para las URLs de imágenes subidas y el callback OAuth):
PUBLIC_URL="http://localhost:3000"
# URL del storefront (destino del redirect OAuth):
FRONTEND_URL="http://localhost:5173"
# URL del panel admin (destino del redirect OAuth cuando state=admin):
ADMIN_URL="http://localhost:5174"
# Correos que entran como ADMIN al iniciar con Google (separados por coma):
ADMIN_EMAILS="nmrcwear@gmail.com"

# === OAuth Google (console.cloud.google.com → APIs & Services → Credentials) ===
# Redirect URI autorizada: {PUBLIC_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# === Cloudinary (cloudinary.com → Dashboard) ===
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY="358738713244282"
CLOUDINARY_API_SECRET=""

# === Moneda (debe coincidir con VITE_USD_RATE del storefront) ===
USD_RATE="510"   # colones por 1 USD

# === Stripe (dashboard.stripe.com → Developers → API keys) ===
# Si se dejan vacías, el checkout usa solo SINPE (fallback automático).
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
# Webhook OPCIONAL (el front confirma vía /payments/confirm). Para demo NO se necesita.
STRIPE_WEBHOOK_SECRET=""

# === PayPal (developer.paypal.com → Apps & Credentials) — opera en Costa Rica ===
# PAYPAL_ENV: "sandbox" para demo, "live" para producción. Sin llaves, se oculta PayPal.
PAYPAL_ENV="sandbox"
PAYPAL_CLIENT_ID=""
PAYPAL_SECRET=""

# === Resend (resend.com → API Keys) para correos transaccionales ===
# Sin clave, los correos se omiten (no-op). MAIL_FROM debe usar un dominio verificado en Resend.
RESEND_API_KEY=""
MAIL_FROM="NMRC <onboarding@resend.dev>"
