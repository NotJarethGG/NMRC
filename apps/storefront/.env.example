# URL base de la API NMRC (incluye /api). En Vercel: Project → Settings → Environment Variables.
VITE_API_URL="http://localhost:3000/api"
# Producción (Render):
# VITE_API_URL="https://nmrc-api.onrender.com/api"

# Moneda: colones por 1 USD (tasa de display para precios en USD)
VITE_USD_RATE="510"

# Correos corporativos
VITE_HELLO_EMAIL="hello@nmrc.store"
VITE_SUPPORT_EMAIL="support@nmrc.store"

# URL pública del sitio (SEO/OG/Schema)
VITE_SITE_URL="https://nmrc-storefront.vercel.app"
